{
  "name": "dustline",
  "version": "1.0.0",
  "description": "DUSTLINE — 1v1 island top-down shooter with Steam P2P",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "ready": "npm run build && node scripts/ready-check.mjs",
    "release": "node scripts/release.mjs",
    "publish:update": "node scripts/publish-update.mjs",
    "site:dev": "npx --yes serve website/public -l 3000",
    "site:deploy": "cd website && npx --yes vercel --prod",
    "start": "vite"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "typescript": "^5.8.3",
    "vite": "^8.1.4"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1"
  }
}
