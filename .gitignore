# Dependencies
node_modules/
.npm/

# Build outputs
dist/
src-tauri/target/
website/.vercel/
*.log

# Env & secrets
.env
.env.*
!.env.example
keys/*.key
keys/*.key.pub.bak
*.pem

# Local release binaries (download from site / CI artifacts)
website/public/downloads/*
!website/public/downloads/.gitkeep
website/public/downloads/**/*.exe
website/public/downloads/**/*.zip
website/public/downloads/**/*.sig

# OS / IDE
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo

# Tauri / generated
src-tauri/gen/schemas/*.json.bak

# Python cache (icon script)
__pycache__/
*.pyc

# Optional local only
*.pdb
.cache/
